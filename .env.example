# PersonalWorkFlow — 環境變數模板
# 複製為 .env，填入真實值（.env 已在 .gitignore，不會被 commit）
#
# 使用方式（Python）:
#   from dotenv import load_dotenv; load_dotenv()

# --- AI API Keys（按需填入）---
OPENAI_API_KEY=sk-replace-me
ANTHROPIC_API_KEY=sk-ant-replace-me

# --- 資料庫連線（若專案需要）---
# MSSQL 範例：
# DB_CONN_STR=mssql+pyodbc://user:password@localhost:1433/dbname?driver=ODBC+Driver+17+for+SQL+Server
# SQLite 範例：
# DB_CONN_STR=sqlite:///./local.db
DB_CONN_STR=replace-me
