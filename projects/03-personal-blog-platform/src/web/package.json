{
  "name": "blog",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cf:dev": "wrangler pages dev --local",
    "cf:deploy": "npx wrangler pages deploy dist --project-name personal-blog-platform --branch main --commit-dirty=true",
    "cf:deploy:image-worker": "npx wrangler deploy -c wrangler.ai-image-worker.jsonc",
    "cf:deploy:auto-pipeline": "npx wrangler deploy -c workers/auto-pipeline/wrangler.toml",
    "db:migrate:local": "wrangler d1 migrations apply BLOG_DB --local",
    "db:migrate": "wrangler d1 migrations apply BLOG_DB"
  },
  "dependencies": {
    "@tiptap/extension-character-count": "^3.23.1",
    "@tiptap/extension-image": "^3.23.1",
    "@tiptap/extension-link": "^3.23.1",
    "@tiptap/extension-placeholder": "^3.23.1",
    "@tiptap/pm": "^3.23.1",
    "@tiptap/react": "^3.23.1",
    "@tiptap/starter-kit": "^3.23.1",
    "dompurify": "^3.4.2",
    "lucide-react": "^0.511.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^6.30.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260510.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.2.4",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wrangler": "^4.88.0"
  }
}
