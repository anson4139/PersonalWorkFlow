# Cloudflare D1 database ID (get from: wrangler d1 create personal-blog-platform-db)
# WRANGLER_DATABASE_ID=

# Admin email (for CF Access setup)
# ADMIN_EMAIL=anson4139@gmail.com

# ---- 以下為 .dev.vars (本機開發) 或 CF Dashboard Environment Variables (生產) ----

# OpenAI API Key
# CF Dashboard: Pages > personal-blog-platform > Settings > Environment Variables
OPENAI_API_KEY=sk-...

# MSSQL 中介 API（不需連線字串，只需呼叫已部署的 HTTP bridge）
MSSQL_BRIDGE_URL=https://your-mssql-bridge.example.com
MSSQL_BRIDGE_SECRET=your-bridge-bearer-token

# Google OAuth 2.0 Client ID（前端 + 後端皆需）
# 建立方式：Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID
#   類型：Web application
#   授權重新導向 URI：https://personal-blog-platform.pages.dev（生產）
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ---- Vite 前端環境變數（放在 .env.local，不進 git）----
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
