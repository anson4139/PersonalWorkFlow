<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <!-- Add custom config sections here -->
  </configSections>

  <connectionStrings>
    <!-- Override in Web.Debug.config / Web.Release.config -->
    <add name="Default"
         connectionString="Server=localhost;Database=MyApp;Integrated Security=true;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <appSettings>
    <add key="AppTitle" value="MyApp" />
  </appSettings>

  <system.web>
    <compilation debug="true" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8" enableVersionHeader="false" />
    <!-- Disable verbose error pages in production via Web.Release.config -->
    <customErrors mode="Off" />
    <!-- Session timeout in minutes -->
    <sessionState timeout="30" />
  </system.web>

  <system.webServer>
    <modules runAllManagedModulesForAllRequests="true" />
    <validation validateIntegratedModeConfiguration="false" />
  </system.webServer>
</configuration>
