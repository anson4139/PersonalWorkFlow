<?xml version="1.0" encoding="utf-8"?>
<!-- Transforms applied when building in Release configuration -->
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <system.web>
    <compilation xdt:Transform="RemoveAttributes(debug)" />
    <customErrors xdt:Transform="SetAttributes" mode="RemoteOnly" />
  </system.web>
  <connectionStrings>
    <!-- Replace connection string in production -->
    <add name="Default"
         connectionString="replace-with-production-connection-string"
         providerName="System.Data.SqlClient"
         xdt:Transform="SetAttributes"
         xdt:Locator="Match(name)" />
  </connectionStrings>
</configuration>
